# Octopus Environment Variables
# Copy this file to .env in your repo root and fill in your values.
# NEVER commit .env — it contains secrets.

# === Notion ===
NOTION_API_TOKEN=
NOTION_WORKSPACE_ID=

# === Slack ===
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=

# === Postgres ===
DATABASE_URL=

# === GitHub ===
GITHUB_TOKEN=

# === X ===
# Use either a user access token for the v2 API or OAuth 1.0a app/user credentials.
X_USER_ACCESS_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_EXPECTED_USERNAME=

# === General ===
# Auto-set by setup.sh — do not change manually
OCTOPUS_PROJECT_ROOT=
