#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# Absolute path of the running shim — sync_shim replaces this file in place.
SELF_PATH="$SCRIPT_DIR/${BASH_SOURCE[0]##*/}"
CACHE_ROOT="${OCTOPUS_CLI_CACHE_ROOT:-$HOME/.octopus-cli}"
CACHE_DIR="$CACHE_ROOT/cache"
METADATA_FILE="$CACHE_ROOT/metadata.json"

# Determine RELEASE_ROOT: prefer local submodule, fall back to globally cached release.
# Uses plain readlink (no -f) because current always points to an absolute path.
_resolve_release_root() {
  local candidate
  candidate="$(cd "$SCRIPT_DIR/.." && pwd)"
  if [[ -f "$candidate/cli/octopus.sh" ]]; then
    echo "$candidate"
  elif [[ -L "$CACHE_ROOT/current" ]]; then
    readlink "$CACHE_ROOT/current"
  else
    echo "$candidate"
  fi
}
RELEASE_ROOT="$(_resolve_release_root)"

LOCKFILE_NAME=".octopus/cli-lock.yaml"

RELEASE_OWNER="${OCTOPUS_RELEASE_OWNER:-leocosta}"
RELEASE_REPO="${OCTOPUS_RELEASE_NAME:-octopus}"
API_ENDPOINT="${OCTOPUS_API_ENDPOINT:-https://api.github.com/repos/$RELEASE_OWNER/$RELEASE_REPO/releases/latest}"

cli_version_from_git() {
  git -C "$RELEASE_ROOT" describe --tags --abbrev=0 2>/dev/null \
    || git -C "$RELEASE_ROOT" rev-parse --short HEAD 2>/dev/null \
    || true
}

resolve_latest_remote_version() {
  local payload
  payload="$(curl -fsSL "$API_ENDPOINT" 2>/dev/null || true)"
  if [[ -n "$payload" ]]; then
    printf '%s' "$payload" | grep '"tag_name"' | head -n1 | sed -E 's/.*"([^"]+)".*/\1/'
  fi
}

find_lockfile() {
  local dir="$PWD"
  while [[ -n "$dir" && "$dir" != "/" ]]; do
    if [[ -f "$dir/$LOCKFILE_NAME" ]]; then
      echo "$dir/$LOCKFILE_NAME"
      return 0
    fi
    dir="$(dirname "$dir")"
  done
  return 1
}

read_lock_version() {
  local lockfile="$1"
  grep -E '^version:' "$lockfile" 2>/dev/null | awk '{print $2}' | head -n1
}

read_metadata_field() {
  local key="$1"
  [[ -f "$METADATA_FILE" ]] || return 1
  grep -o "\"$key\"[[:space:]]*:[[:space:]]*\"[^\"]*\"" "$METADATA_FILE" \
    | sed -E "s/\"$key\"[[:space:]]*:[[:space:]]*\"([^\"]*)\"/\\1/" \
    | head -n1
}

resolve_version() {
  if lockfile="$(find_lockfile)"; then
    local lock_version
    lock_version="$(read_lock_version "$lockfile")"
    [[ -n "$lock_version" ]] && { echo "$lock_version"; return 0; }
  fi
  local meta_version
  meta_version="$(read_metadata_field "version" || true)"
  if [[ -n "$meta_version" ]]; then
    echo "$meta_version"
    return 0
  fi
  cli_version_from_git
}

# Resolves the target version for `octopus update` (no explicit flag).
# Unlike resolve_version, this never falls back to metadata.json — that
# field records what is already installed, not where `update` should go.
resolve_update_target() {
  if lockfile="$(find_lockfile)"; then
    local lock_version
    lock_version="$(read_lock_version "$lockfile")"
    [[ -n "$lock_version" ]] && { echo "$lock_version"; return 0; }
  fi
  local remote
  remote="$(resolve_latest_remote_version || true)"
  if [[ -n "$remote" ]]; then
    echo "$remote"
    return 0
  fi
  cli_version_from_git
}

ensure_cache_dirs() {
  mkdir -p "$CACHE_DIR"
}

_release_matches_version() {
  local root="$1"
  local version="$2"
  [[ -f "$root/cli/octopus.sh" ]] || return 1
  [[ -d "$root/.git" ]] || return 1
  local tag
  tag="$(git -C "$root" describe --tags --exact-match HEAD 2>/dev/null || true)"
  [[ -n "$tag" && "$tag" == "$version" ]]
}

_download_release_via_installer() {
  local version="$1"
  local installer
  local installer_tmp=""
  # Always prefer a fresh copy from the target release's install.sh so
  # updates pick up installer improvements (e.g. banner removal) immediately.
  installer_tmp="$(mktemp)"
  local url="https://raw.githubusercontent.com/$RELEASE_OWNER/$RELEASE_REPO/main/install.sh"
  if curl -fsSL "$url" -o "$installer_tmp" 2>/dev/null; then
    installer="$installer_tmp"
  elif [[ -x "$RELEASE_ROOT/install.sh" ]]; then
    rm -f "$installer_tmp"
    installer_tmp=""
    installer="$RELEASE_ROOT/install.sh"
  else
    rm -f "$installer_tmp"
    echo "Error: failed to fetch installer from $url" >&2
    return 1
  fi
  OCTOPUS_CACHE_DIR="$CACHE_ROOT" bash "$installer" \
    --version "$version" --no-shim-setup --force
  local rc=$?
  [[ -n "$installer_tmp" ]] && rm -f "$installer_tmp"
  return "$rc"
}

install_release() {
  local version="$1"
  ensure_cache_dirs
  local target="$CACHE_DIR/$version"

  # Bootstrap case: the shim is already inside the cache at the target path.
  if [[ "$RELEASE_ROOT" == "$target" ]]; then
    mkdir -p "$target"
    local checksum
    checksum="$(compute_release_checksum "$RELEASE_ROOT")"
    write_metadata "$version" "$checksum"
    echo "Installed Octopus $version (cached at $target)"
    return 0
  fi

  # Dev checkout whose tag matches the requested version: symlink it.
  if _release_matches_version "$RELEASE_ROOT" "$version"; then
    [[ -L "$target" || -e "$target" ]] && rm -rf "$target"
    ln -s "$RELEASE_ROOT" "$target"
    local checksum
    checksum="$(compute_release_checksum "$target")"
    write_metadata "$version" "$checksum"
    echo "Installed Octopus $version (cached at $target)"
    return 0
  fi

  # RELEASE_ROOT is a different version — download the requested release
  # instead of stamping its name on the wrong tree.
  [[ -L "$target" || -e "$target" ]] && rm -rf "$target"
  if ! _download_release_via_installer "$version"; then
    echo "Error: could not install Octopus $version." >&2
    echo "Try: curl -fsSL https://github.com/$RELEASE_OWNER/$RELEASE_REPO/releases/latest/download/install.sh | bash -s -- --version $version --force" >&2
    exit 1
  fi
  if [[ ! -f "$target/cli/octopus.sh" ]]; then
    echo "Error: installer completed but $target is missing expected files." >&2
    exit 1
  fi
  local checksum
  checksum="$(compute_release_checksum "$target")"
  write_metadata "$version" "$checksum"
  echo "Installed Octopus $version (cached at $target)"
}

# `octopus update` invokes the installer with --no-shim-setup, so the freshly
# cached release updates everything EXCEPT the running shim (bin/octopus). Any
# change to the shim itself — e.g. a new global command — would then only reach
# users via a full reinstall, never via `update`. Sync it here: copy the target
# release's shim over the running one via an atomic rename. Overwriting the
# script currently executing is safe because the kernel keeps the open inode
# alive until this process exits; the rename only swaps the directory entry.
sync_shim() {
  local version="$1"
  local source dir tmp
  source="$(release_dir_for "$version")/bin/octopus"

  [[ -f "$source" ]] || return 0                # release ships no shim — nothing to sync
  [[ "$SELF_PATH" -ef "$source" ]] && return 0  # dev checkout / running from cache
  cmp -s "$SELF_PATH" "$source" && return 0     # already identical — no-op

  dir="$(dirname "$SELF_PATH")"
  if [[ ! -w "$dir" ]]; then
    echo "  ⚠ shim at $SELF_PATH is stale but $dir is not writable." >&2
    echo "    Reinstall to refresh it: curl -fsSL https://github.com/$RELEASE_OWNER/$RELEASE_REPO/releases/latest/download/install.sh | bash" >&2
    return 0
  fi

  tmp="$(mktemp "$dir/.octopus-shim.XXXXXX")" || return 0
  if cp "$source" "$tmp" && chmod +x "$tmp" && mv -f "$tmp" "$SELF_PATH"; then
    echo "Refreshed shim at $SELF_PATH"
  else
    rm -f "$tmp"
    echo "  ⚠ failed to refresh shim at $SELF_PATH — reinstall manually." >&2
  fi
}

write_metadata() {
  local version="$1"
  local checksum="$2"
  local timestamp
  timestamp="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  mkdir -p "$(dirname "$METADATA_FILE")"
  cat > "$METADATA_FILE" <<EOF
{
  "version": "$version",
  "checksum": "$checksum",
  "installed_at": "$timestamp",
  "release_path": "$RELEASE_ROOT"
}
EOF
}

compute_release_checksum() {
  local root="$1"
  if git -C "$root" rev-parse HEAD >/dev/null 2>&1; then
    git -C "$root" rev-parse HEAD
    return
  fi

  (cd "$root" && find . -type f -print0 | LC_ALL=C sort -z | xargs -0 sha256sum | sha256sum | awk '{print $1}')
}

find_project_root() {
  local dir="$PWD"
  while [[ -n "$dir" && "$dir" != "/" ]]; do
    if [[ -f "$dir/.octopus.yml" || -d "$dir/.git" ]]; then
      echo "$dir"
      return 0
    fi
    dir="$(dirname "$dir")"
  done
  echo "$PWD"
}

pin_lockfile() {
  local version="$1"
  local checksum="$2"
  local lockfile
  if lockfile="$(find_lockfile)"; then
    :
  else
    local project
    project="$(find_project_root)"
    lockfile="$project/$LOCKFILE_NAME"
  fi
  mkdir -p "$(dirname "$lockfile")"
  cat > "$lockfile" <<EOF
version: $version
checksum: $checksum
EOF
  echo "Pinned Octopus $version in $lockfile"
}

release_dir_for() {
  local version="$1"
  echo "$CACHE_DIR/$version"
}

ensure_release_for() {
  local version="$1"
  local release_dir
  release_dir="$(release_dir_for "$version")"
  if [[ ! -e "$release_dir" && ! -L "$release_dir" ]]; then
    install_release "$version"
  fi
}

# Hook commands in a project's settings.json are rewritten to version-pinned
# cache paths; after an update those can point at a release that no longer
# exists and error at session start. Flag any that are gone.
_doctor_stale_hooks() {
  local settings="$1" issues=0 cmd
  [[ -f "$settings" ]] || return 0
  while IFS= read -r cmd; do
    [[ -n "$cmd" && ! -e "$cmd" ]] || continue
    echo "  ⚠ stale hook path: $cmd"
    issues=$((issues + 1))
  done < <(grep -oE '"command"[[:space:]]*:[[:space:]]*"[^"]*\.octopus-cli/cache/[^"]*"' "$settings" 2>/dev/null \
            | sed -E 's/.*:[[:space:]]*"([^"]*)".*/\1/')
  return "$issues"
}

# Versioned cache entries that are symlinks to a now-missing target.
_doctor_broken_symlinks() {
  local issues=0 entry
  [[ -d "$CACHE_DIR" ]] || return 0
  for entry in "$CACHE_DIR"/*; do
    [[ -L "$entry" && ! -e "$entry" ]] || continue
    echo "  ⚠ broken cache symlink: $(basename "$entry") -> $(readlink "$entry")"
    issues=$((issues + 1))
  done
  return "$issues"
}

# Best-effort: a newer release than the one installed. Silent when offline.
_doctor_version_drift() {
  local installed="$1" latest
  latest="$(resolve_latest_remote_version 2>/dev/null || true)"
  [[ -n "$latest" && "${installed#v}" != "${latest#v}" ]] || return 0
  echo "  ⚠ newer release available: $latest (installed: $installed) — run 'octopus update'"
  return 1
}

doctor() {
  local version
  version="$(resolve_version)"
  if [[ -z "$version" ]]; then
    echo "No installed release."
    return 1
  fi
  local release_dir
  release_dir="$(release_dir_for "$version")"
  echo "Installed Octopus version: $version"
  echo "Tracked release directory: $release_dir"
  [[ -f "$METADATA_FILE" ]] && echo "Metadata: $METADATA_FILE"
  [[ -e "$release_dir" ]] && echo "Release available." || echo "  ⚠ tracked release directory is missing — run 'octopus install'"

  echo "Health:"
  local issues=0
  _doctor_stale_hooks "$(find_project_root)/.claude/settings.json" || issues=$((issues + $?))
  _doctor_stale_hooks "$HOME/.claude/settings.json"               || issues=$((issues + $?))
  _doctor_broken_symlinks                                          || issues=$((issues + $?))
  _doctor_version_drift "$version"                                 || issues=$((issues + $?))
  if [[ "$issues" -eq 0 ]]; then
    echo "  ✓ no issues found"
  else
    echo "  $issues issue(s) found"
  fi
  return 0
}

run_subcommand() {
  local command="$1"
  shift
  local version
  version="$(resolve_version)"
  ensure_release_for "$version"
  local project_root
  project_root="$(find_project_root)"
  local release_dir
  release_dir="$(release_dir_for "$version")"
  (cd "$project_root" && "$release_dir/cli/octopus.sh" "$command" "$@")
}

command_install() {
  local version=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --version)
        version="$2"
        shift 2
        ;;
      --latest)
        echo "Resolving latest version..."
        version="$(resolve_latest_remote_version || cli_version_from_git)"
        shift
        ;;
      *)
        echo "Unknown option: $1"
        exit 1
        ;;
    esac
  done
  if [[ -z "$version" ]]; then
    echo "Resolving latest version..."
    version="$(resolve_latest_remote_version || cli_version_from_git)"
  fi
  echo "Installing Octopus $version..."
  install_release "$version"
  echo "Done. Run 'octopus doctor' to verify."
}

command_update() {
  local version=""
  local pin=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --version)
        version="$2"
        shift 2
        ;;
      --latest)
        echo "Resolving latest version..."
        version="$(resolve_latest_remote_version || cli_version_from_git)"
        shift
        ;;
      --pin)
        pin=true
        shift
        ;;
      *)
        echo "Unknown option: $1"
        exit 1
        ;;
    esac
  done
  if [[ -z "$version" ]]; then
    if lockfile="$(find_lockfile)"; then
      echo "Using version pinned in $lockfile..."
    else
      echo "Resolving latest version..."
    fi
    version="$(resolve_update_target)"
  fi
  echo "Updating to Octopus $version..."
  install_release "$version"
  sync_shim "$version"
  local checksum
  checksum="$(compute_release_checksum "$RELEASE_ROOT")"
  if [[ "$pin" == true ]]; then
    pin_lockfile "$version" "$checksum"
  fi
  local project_root
  project_root="$(find_project_root)"
  if [[ -f "$project_root/.octopus.yml" ]]; then
    echo "Re-running setup..."
    if run_subcommand setup --scope=repo; then
      echo "Setup complete — agent configs regenerated."
    else
      echo "Setup failed — run 'octopus setup' manually to regenerate agent configs."
    fi
  else
    echo "No .octopus.yml found — skipping setup. Run 'octopus setup' manually."
  fi
}

command_setup() {
  local version
  version="$(resolve_version)"
  ensure_release_for "$version"
  run_subcommand setup "$@"
}

print_help() {
  cat <<EOF
Usage: octopus <command> [args]

Global commands (version management — handled by the shim):
  install [--version <tag>] [--latest]   Install a release into the local cache
  update [--version <tag>] [--latest] [--pin]
  setup [--scope=repo|user] [--reconfigure] [--dry-run]
                                          Configure Octopus for this repo (default) or user account
  doctor                                 Inspect the cached installation
EOF
  # Workflow commands come from the release's command registry (RM-113), so this
  # list never drifts from what cli/octopus.sh actually dispatches.
  local registry="$RELEASE_ROOT/cli/lib/commands.default"
  if [[ -f "$registry" ]]; then
    echo ""
    echo "Workflow commands:"
    awk -F'|' '/^[^#]/ && NF>=2 { printf "  %-14s %s\n", $1, $2 }' "$registry"
  else
    echo "  <other>                                Delegate to the existing workflow CLI"
  fi
}

print_version() {
  local v
  v="$(resolve_version 2>/dev/null || true)"
  echo "octopus ${v:-unknown}"
}

command="${1:-}"
shift || true
case "$command" in
  install)
    command_install "$@"
    ;;
  update)
    command_update "$@"
    ;;
  setup)
    command_setup "$@"
    ;;
  doctor)
    doctor
    ;;
  version | -v | --version)
    print_version
    ;;
  help)
    # `octopus help <cmd>` delegates to the workflow CLI for the per-command
    # summary; bare `octopus help` prints the unified help.
    if [[ $# -gt 0 ]]; then run_subcommand help "$@"; else print_help; fi
    ;;
  "" | -h | --help)
    print_help
    ;;
  *)
    run_subcommand "$command" "$@"
    ;;
esac
